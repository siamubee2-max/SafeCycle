# SafeCycle Mobile — Environment Variables
# Copy to .env.local and fill in real values.
# These are prefixed EXPO_PUBLIC_ to be accessible in the JS bundle.
# They do NOT include sensitive server secrets.

# URL of the hosted SafeCycle web app (PWA)
# For local dev, use your machine's LAN IP: http://192.168.x.x:3000
EXPO_PUBLIC_WEB_APP_URL=https://inferencevision.store/safecycle

# RevenueCat API Keys — get from app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_RC_APPLE_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_RC_GOOGLE_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
