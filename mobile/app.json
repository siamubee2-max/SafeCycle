      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "92a5d3d3-eb9e-489c-92dd-63db087c728c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
